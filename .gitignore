# ---------- Data — raw (se descarga, NO se versiona) ----------
data/raw/*.nc
data/raw/*.zip
data/raw/*.shp
data/raw/*.dbf
data/raw/*.shx
data/raw/*.prj
data/raw/*.cpg
data/raw/*.geojson
data/raw/*.gpkg
data/raw/era5_*
data/raw/cuencas_*
data/raw/nivel_sirh_*
data/raw/*.tgz
data/raw/*.tar.gz

# Excepto el CSV SIMMA que sí versionamos (viene en el repo)
!data/raw/Resultados_SIMMA.csv

# ---------- Data — processed (se regenera, NO se versiona) ----------
data/processed/*.csv
data/processed/*.parquet
data/processed/*.feather
data/processed/*.nc

# ---------- Outputs — figuras y simulaciones ----------
outputs/figures/*.png
outputs/figures/*.jpg
outputs/figures/*.pdf
outputs/simulations/*.gif
outputs/simulations/*.mp4
outputs/simulations/*.pkl

# Mantener estructura de carpetas vacías
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
!outputs/figures/.gitkeep
!outputs/simulations/.gitkeep

